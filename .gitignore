# ==== Data and models — версионируются через DVC, не git ====
# В git попадают только .dvc-метаданные и .gitkeep, сами данные — в DVC remote.
data/raw/*
data/interim/*
data/processed/*
data/external/*
data/featurized/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep
!data/featurized/.gitkeep
!data/raw/*.dvc
!data/interim/*.dvc
!data/processed/*.dvc
!data/external/*.dvc
models/*
!models/.gitkeep
!models/*.dvc

# ==== Reports artifacts (figures + scored deliverable генерируются) ====
reports/figures/*
!reports/figures/.gitkeep
# Scored test dataset — большой (~13 MB), регенерируется через
# `python -m src.models.score_dataset`. В git только сам скрипт.
reports/scored_test_dataset.parquet
reports/scored_test_dataset.csv
reports/scored_test_dataset.xlsx

# ==== Jupyter ====
.ipynb_checkpoints/
*.ipynb_meta

# ==== Logs ====
*.log
logs/

# ==== Docker ====
*.pid
